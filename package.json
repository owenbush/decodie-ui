{
  "name": "@owenbush/decodie-ui",
  "version": "2.0.5",
  "description": "Presentation layer for Decodie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/owenbush/decodie-ui.git"
  },
  "bin": {
    "decodie": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/public"
  ],
  "scripts": {
    "build": "tsc && cp node_modules/@owenbush/decodie-ui-shared/dist/styles/main.css src/public/shared.css",
    "dev": "tsx src/cli.ts serve",
    "start": "node dist/cli.js serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/xai": "^3.0.90",
    "@owenbush/decodie-core": "^1.0.0",
    "@owenbush/decodie-ui-shared": "^0.5.0",
    "ai": "^6.0.182",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "express": "^4.21.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
